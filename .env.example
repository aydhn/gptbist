# ==============================================================================
# BIST SIGNAL BOT - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env and adjust the values according to your needs.
# The .env file is intentionally excluded from version control (.gitignore).

# ------------------------------------------------------------------------------
# 1. APP / RUNTIME
# ------------------------------------------------------------------------------
# Environment: development, test, or production
APP_ENV=development

# Run mode: research, backtest, paper, live_signal
# Note: Real trading (live_order) is not supported in this phase.
RUN_MODE=research

# Dry run mode disables actual external modifications (e.g. sending real telegram msgs)
DRY_RUN=true

# ------------------------------------------------------------------------------
# 2. PATHS
# ------------------------------------------------------------------------------
# Relative or absolute paths for storage directories
DATA_DIR=data
CACHE_DIR=data/cache
REPORTS_DIR=data/reports

# ------------------------------------------------------------------------------
# 3. DATA PROVIDER
# ------------------------------------------------------------------------------
DEFAULT_DATA_PROVIDER=yfinance
DEFAULT_TIMEFRAME=1d
DEFAULT_HISTORY_PERIOD=2y
DATA_PROVIDER_TIMEOUT_SECONDS=30
DATA_PROVIDER_MAX_RETRIES=2

# ------------------------------------------------------------------------------
# 4. STORAGE
# ------------------------------------------------------------------------------
STORAGE_FORMAT=csv
PREFER_LOCAL_DATA=true
SAVE_FETCHED_DATA=true

# ------------------------------------------------------------------------------
# 5. DATA QUALITY
# ------------------------------------------------------------------------------
ENABLE_DATA_QUALITY_CHECK=true
DATA_QUALITY_MIN_ROWS=100
DATA_QUALITY_MAX_DAILY_RETURN_ABS=0.35
DATA_QUALITY_MAX_ALLOWED_GAP_DAYS=10
DATA_QUALITY_FAIL_ON_ERROR=false

# ------------------------------------------------------------------------------
# 6. MARKET CALENDAR
# ------------------------------------------------------------------------------
BIST_REGULAR_OPEN=10:00
BIST_REGULAR_CLOSE=18:00
BIST_SIGNAL_AFTER_CLOSE_MINUTES=15
BIST_INTRADAY_SIGNAL_ENABLED=false
BIST_DAILY_SIGNAL_ENABLED=true
# Comma separated ISO dates (YYYY-MM-DD)
BIST_MANUAL_HOLIDAYS=2026-01-01,2026-04-23,2026-05-01

# ------------------------------------------------------------------------------
# 7. TELEGRAM (NOTIFICATIONS)
# ------------------------------------------------------------------------------
ENABLE_TELEGRAM=false
TELEGRAM_DRY_RUN=true
# Replace with your actual bot token and chat id when deploying
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true
TELEGRAM_MESSAGE_MAX_LENGTH=3900

# What to notify about
SEND_STARTUP_NOTIFICATION=true
SEND_HEALTHCHECK_NOTIFICATION=false
SEND_ERROR_NOTIFICATIONS=true
SEND_DATA_QUALITY_WARNINGS=true

# ------------------------------------------------------------------------------
# 8. LOGGING
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_NAME=bist_signal_bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
MASK_SECRETS_IN_LOGS=true
DEBUG_TRACEBACKS=false

# ------------------------------------------------------------------------------
# 9. AUDIT
# ------------------------------------------------------------------------------
ENABLE_AUDIT_LOG=true
AUDIT_LOG_FILE_NAME=audit.log

# ------------------------------------------------------------------------------
# 10. ML
# ------------------------------------------------------------------------------
ENABLE_ML=false
ENABLE_GPU=false
ML_RANDOM_SEED=42
ML_MODEL_DIR=data/models

# ------------------------------------------------------------------------------
# 11. OPTIMIZER
# ------------------------------------------------------------------------------
ENABLE_OPTIMIZER=false
OPTIMIZER_RANDOM_SEED=42
OPTIMIZER_MAX_TRIALS=100

# ------------------------------------------------------------------------------
# 12. BACKTEST
# ------------------------------------------------------------------------------
BACKTEST_INITIAL_CAPITAL=100000.0
BACKTEST_COMMISSION_RATE=0.002
BACKTEST_SLIPPAGE_RATE=0.001
BACKTEST_ALLOW_SHORT=false

# ------------------------------------------------------------------------------
# 13. RISK
# ------------------------------------------------------------------------------
MAX_POSITION_SIZE_PCT=0.10
MAX_PORTFOLIO_RISK_PCT=0.02
MAX_DAILY_SIGNALS=10


# ------------------------------------------------------------------------------
# 14. CORPORATE ACTIONS & ADJUSTMENTS
# ------------------------------------------------------------------------------
CORPORATE_ACTIONS_DIR_NAME=corporate_actions
CORPORATE_ACTIONS_FILE_NAME=corporate_actions.json
AUTO_INITIALIZE_CORPORATE_ACTIONS=true
ENABLE_PRICE_ADJUSTMENTS=false
DEFAULT_ADJUSTMENT_POLICY=FLAG_ONLY
ADJUSTMENT_SAVE_ADJUSTED_DATA=false
ADJUSTMENT_APPLY_TO_OHLC=true
ADJUSTMENT_APPLY_TO_VOLUME=true
ADJUSTMENT_FAIL_ON_ERROR=true
ADJUSTMENT_REQUIRE_VERIFIED_ACTIONS=false

# === COST MODEL (Phase 26) ===
ENABLE_COST_MODEL=True
COST_SCENARIO=BASE

COMMISSION_MODEL_TYPE=BPS
COMMISSION_BPS=5.0
COMMISSION_FLAT_FEE=0.0
COMMISSION_MINIMUM=0.0
TRANSACTION_TAX_BPS=0.0
OTHER_FEE_BPS=0.0

SLIPPAGE_MODEL_TYPE=HYBRID
FIXED_SLIPPAGE_BPS=5.0
VOLUME_IMPACT_FACTOR=10.0
VOLATILITY_IMPACT_FACTOR=0.25
MIN_SLIPPAGE_BPS=0.0
MAX_SLIPPAGE_BPS=100.0

SPREAD_MODEL_TYPE=LIQUIDITY_BUCKET
FIXED_SPREAD_BPS=5.0
HIGH_LIQUIDITY_SPREAD_BPS=3.0
MEDIUM_LIQUIDITY_SPREAD_BPS=8.0
LOW_LIQUIDITY_SPREAD_BPS=20.0

LIQUIDITY_HIGH_TURNOVER_TRY=100000000.0
LIQUIDITY_MEDIUM_TURNOVER_TRY=10000000.0
COST_DEFAULT_AVG_DAILY_VOLUME=0.0
COST_DEFAULT_AVG_DAILY_TURNOVER=0.0

# === Paper Trading Settings ===
# ENABLE_PAPER_TRADING=true
# PAPER_INITIAL_CASH=100000.0
# PAPER_REQUIRE_RISK_APPROVAL=true
# PAPER_USE_PORTFOLIO_RISK=true
# PAPER_USE_TRADE_RISK=true
# PAPER_EXECUTION_MODE="LATEST_CLOSE_RESEARCH"
# PAPER_SEND_TELEGRAM_SUMMARY=false
# SIGNAL SCANNER
ENABLE_SIGNAL_SCANNER=True
SCANNER_DEFAULT_STRATEGY=moving_average_trend
SCANNER_DEFAULT_SOURCE=mock
SCANNER_DEFAULT_TIMEFRAME=1d
SCANNER_DEFAULT_TOP_N=10
SCANNER_CONTINUE_ON_ERROR=True
SCANNER_SAVE_REPORT=False
SCANNER_REPORT_FORMATS=json,csv,markdown
SCANNER_SEND_TELEGRAM=False

SCANNER_USE_TRADE_RISK=True
SCANNER_USE_PORTFOLIO_RISK=True
SCANNER_MIN_SIGNAL_SCORE=50.0
SCANNER_MIN_CONFIDENCE=40.0
SCANNER_MIN_FINAL_SCORE=50.0
SCANNER_INCLUDE_WATCH_ONLY=True
SCANNER_INCLUDE_REJECTED_IN_REPORT=True

SCANNER_SORT_KEY=FINAL_SCORE
SCANNER_SORT_DESCENDING=True
SCANNER_LOW_COST_MAX_BPS=100.0
SCANNER_LOW_VOLATILITY_MAX_SCORE=100.0

SCANNER_MAX_SYMBOLS_PER_RUN=100
SCANNER_DEFAULT_WATCHLIST=default
SCANNER_DEFAULT_GROUP=LIQUID

SCANNER_ALLOW_PAPER_EXECUTION=False
SCANNER_USE_PAPER=False

SCANNER_RESULTS_DIR_NAME=scans

# OPTIMIZATION
ENABLE_OPTIMIZATION=True
OPTIMIZATION_DEFAULT_METHOD=GRID_SEARCH
OPTIMIZATION_DEFAULT_OBJECTIVE=COMPOSITE
OPTIMIZATION_MAX_COMBINATIONS=100
OPTIMIZATION_RANDOM_SEED=42
OPTIMIZATION_TOP_N=10
OPTIMIZATION_SAVE_REPORT=False

# Optimization Constraints
OPTIMIZATION_MIN_TRADES=3
OPTIMIZATION_MAX_DRAWDOWN_PCT=40.0

# Optimization Walk-Forward
OPTIMIZATION_WALK_FORWARD_ENABLED=False
OPTIMIZATION_WF_TRAIN_WINDOW_ROWS=252
OPTIMIZATION_WF_TEST_WINDOW_ROWS=63
OPTIMIZATION_WF_STEP_ROWS=63

# ML TRAINING
ENABLE_ML_TRAINING=true
ML_TRAIN_DEFAULT_MODEL_TYPE=RANDOM_FOREST_CLASSIFIER
ML_TRAIN_DEFAULT_TASK_TYPE=CLASSIFICATION
ML_TRAIN_TARGET_COL=label_direction_binary_5
ML_TRAIN_SCALER=NONE
ML_TRAIN_IMPUTER=MEDIAN
ML_TRAIN_RATIO=0.70
ML_TRAIN_RANDOM_SEED=42
ML_TRAIN_MAX_TRAIN_ROWS=0
ML_TRAIN_SAVE_MODEL=true
ML_TRAIN_SAVE_REPORT=false
ML_TRAIN_REPORT_FORMATS=json,markdown,csv

# ML INFERENCE
ENABLE_ML_INFERENCE=true
ML_INFERENCE_DEFAULT_MODEL_ID=""
ML_INFERENCE_MODE="SCORE_AND_FILTER"
ML_SCORE_BLEND_MODE="WEIGHTED_AVERAGE"
ML_SCORE_WEIGHT=0.35
ML_STRATEGY_SCORE_WEIGHT=0.65
ML_MIN_PROBABILITY_POSITIVE=0.55
ML_MAX_PROBABILITY_NEGATIVE=0.60
ML_MIN_PREDICTION_SCORE=50.0
ML_REJECT_ON_MISSING_FEATURES=true
ML_ALLOW_EXTRA_FEATURES=true
ML_LATEST_ONLY=true

STRATEGY_USE_ML_FILTER=false
STRATEGY_ML_MODEL_ID=""

SCANNER_USE_ML_FILTER=false
SCANNER_ML_MODEL_ID=""
SCANNER_MIN_ML_SCORE=50.0
SCANNER_MIN_ML_PROBABILITY=0.55

RISK_USE_ML_FILTER=false
RISK_MIN_ML_SCORE=50.0
RISK_MIN_ML_PROBABILITY_POSITIVE=0.55
RISK_REJECT_IF_ML_MISSING=false

BACKTEST_USE_ML_FILTER=false
BACKTEST_ML_MODEL_ID=""

PAPER_USE_ML_FILTER=false
PAPER_ML_MODEL_ID=""

# Runtime Orchestrator
ENABLE_RUNTIME_ORCHESTRATOR=true
RUNTIME_MODE="RUN_ONCE"
RUNTIME_INTERVAL_MINUTES=60
RUNTIME_SCHEDULER_ENABLED=false
RUNTIME_USE_PAPER=false
RUNTIME_SEND_TELEGRAM=false

# ------------------------------------------------------------------------------
# SECURITY GUARD
# ------------------------------------------------------------------------------
ENABLE_SECURITY_GUARD=true
SECURITY_LEVEL=HIGH
SECURITY_FAIL_ON_SECRET_LEAK=true
SECURITY_BLOCK_REAL_ORDER_ACTIONS=true
SECURITY_BLOCK_BROKER_API=true
SECURITY_BLOCK_HTML_SCRAPING=true
SECURITY_BLOCK_UNSAFE_CLAIMS=true
SECURITY_SANITIZE_UNSAFE_CLAIMS=true
SECURITY_ENFORCE_SAFE_PATHS=true
SECURITY_ALLOW_EXTERNAL_MODEL_PATH=false
SECURITY_KILL_SWITCH_ENABLED=true
SECURITY_KILL_SWITCH_FILE_NAME=kill_switch.json

# --- Quality Gate Settings ---
ENABLE_QUALITY_GATE=true
QUALITY_RESULTS_DIR_NAME=quality
QUALITY_DEFAULT_SUITE=FAST
QUALITY_GATE_LEVEL=STANDARD
QUALITY_SAVE_REPORT=true
QUALITY_REPORT_FORMATS=json,markdown,csv
QUALITY_RUN_TESTS=true
QUALITY_RUN_COVERAGE=false
QUALITY_RUN_STATIC=true
QUALITY_RUN_TYPE_CHECK=false
QUALITY_RUN_IMPORT_CHECKS=true
QUALITY_RUN_SECURITY_CHECKS=true
QUALITY_RUN_REGRESSION_SMOKE=false
QUALITY_FAIL_ON_WARNING=false
QUALITY_COVERAGE_THRESHOLD_PCT=60.0
QUALITY_TIMEOUT_SECONDS=300
QUALITY_SMOKE_COMMAND_TIMEOUT_SECONDS=60
QUALITY_WARN_IF_TOOL_MISSING=true
QUALITY_STRICT_FAIL_IF_TOOL_MISSING=false
RUNTIME_QUALITY_PREFLIGHT_ENABLED=false
RUNTIME_QUALITY_PREFLIGHT_SUITE=SMOKE

# --- Packaging Configuration ---
# Format: MANIFEST_ONLY or ZIP
PACKAGING_DEFAULT_FORMAT=MANIFEST_ONLY
PACKAGING_DIR_NAME=packaging
PACKAGING_MIN_PYTHON_VERSION=3.10
PACKAGING_RUN_QUALITY_BY_DEFAULT=false
PACKAGING_RUN_SECURITY_BY_DEFAULT=true
PACKAGING_INCLUDE_INSTALLERS=true

# Docs
ENABLE_DOCS=true
DOCS_SOURCE_DIR_NAME=docs
DOCS_REPORTS_DIR_NAME=docs
DOCS_VALIDATE_ON_QUALITY=true

# ------------------------------------------------------------------------------
# 15. PERFORMANCE & RESOURCES (Phase 45)
# ------------------------------------------------------------------------------
ENABLE_PERFORMANCE_TOOLS=true
PERFORMANCE_DIR_NAME=performance
PERFORMANCE_SAVE_REPORTS=true
PERFORMANCE_REPORT_FORMATS=json,markdown,csv
PERFORMANCE_USE_PSUTIL_IF_AVAILABLE=true
PERFORMANCE_CHECK_GPU=true
PERFORMANCE_MEMORY_WARN_PCT=80.0
PERFORMANCE_MEMORY_CRITICAL_PCT=92.0
PERFORMANCE_DISK_WARN_PCT=85.0
PERFORMANCE_DISK_CRITICAL_PCT=95.0
PERFORMANCE_PROFILE_ENABLED=false
PERFORMANCE_PROFILE_TOP_N=20
PERFORMANCE_PROFILE_TIMEOUT_SECONDS=300
PERFORMANCE_CONCURRENCY_MODE=SERIAL
PERFORMANCE_MAX_WORKERS=1
PERFORMANCE_DEFAULT_BATCH_SIZE=10
PERFORMANCE_MAX_BATCH_SIZE=50
PERFORMANCE_SCANNER_SLOW_SYMBOL_SECONDS=5.0
PERFORMANCE_CACHE_POLICY=DRY_RUN_ONLY
PERFORMANCE_CACHE_MAX_AGE_DAYS=30
PERFORMANCE_CACHE_MAX_TOTAL_SIZE_MB=2048.0
PERFORMANCE_CACHE_CLEANUP_DRY_RUN=true
PERFORMANCE_CACHE_CLEANUP_REQUIRE_CONFIRM=true
PERFORMANCE_PROTECT_MODEL_ARTIFACTS=true
PERFORMANCE_PROTECT_PAPER_LEDGER=true
PERFORMANCE_PROTECT_RUNTIME_STATE=true
PERFORMANCE_PROTECT_AUDIT_LOGS=true
PERFORMANCE_BENCHMARK_ITERATIONS=3
PERFORMANCE_BENCHMARK_USE_MOCK=true
PERFORMANCE_BENCHMARK_SYMBOLS=ASELS,THYAO,GARAN
PERFORMANCE_BENCHMARK_STRATEGY=moving_average_trend
RUNTIME_USE_PERFORMANCE_METRICS=true

# Research Settings (Phase 47)
ENABLE_RESEARCH_LEDGER=true
RESEARCH_DIR_NAME="research"
RESEARCH_LEDGER_APPEND_ONLY=true
RESEARCH_SAVE_REPORTS=true
RESEARCH_REPORT_FORMATS="json,markdown,csv"
RESEARCH_REQUIRE_CONFIRM_FOR_EDITS=true
RESEARCH_MAX_RECENT_ENTRIES=100
RESEARCH_AUTO_LOG_BACKTEST=true
RESEARCH_AUTO_LOG_SCAN=true
RESEARCH_AUTO_LOG_PAPER=true
RESEARCH_AUTO_LOG_RUNTIME=true
RESEARCH_AUTO_LOG_ADAPTIVE=true
RESEARCH_SIGNAL_JOURNAL_ENABLED=true

# --- Reports Configuration ---
ENABLE_REPORTS=True
REPORTS_DIR_NAME="reports"
REPORT_DEFAULT_TYPE="DAILY"
REPORT_DEFAULT_AUDIENCE="PERSONAL"
REPORT_DEFAULT_FORMATS="markdown,json,csv"
REPORT_SAVE_BY_DEFAULT=True
REPORT_TOP_N=10

REPORT_INCLUDE_EXECUTIVE_SUMMARY=True
REPORT_INCLUDE_MARKET_REGIME=True
REPORT_INCLUDE_SCANNER=True
REPORT_INCLUDE_RISK=True
REPORT_INCLUDE_PORTFOLIO_RISK=True
REPORT_INCLUDE_ML=True
REPORT_INCLUDE_ADAPTIVE=True
REPORT_INCLUDE_PAPER=True
REPORT_INCLUDE_BACKTEST=True
REPORT_INCLUDE_OPTIMIZATION=True
REPORT_INCLUDE_RESEARCH_LEDGER=True
REPORT_INCLUDE_SIGNAL_JOURNAL=True
REPORT_INCLUDE_ATTRIBUTION=True
REPORT_INCLUDE_RUNTIME=True
REPORT_INCLUDE_MONITORING=True
REPORT_INCLUDE_SECURITY=True
REPORT_INCLUDE_QUALITY=True
REPORT_INCLUDE_PERFORMANCE=True

REPORT_TELEGRAM_DIGEST_ENABLED=False
REPORT_TELEGRAM_REQUIRE_CONFIRM=True
REPORT_DIGEST_TOP_N=5
REPORT_DIGEST_MAX_CHARS=3500

RUNTIME_GENERATE_REPORT=False
RUNTIME_REPORT_TYPE="RUNTIME_SUMMARY"
RUNTIME_SEND_REPORT_DIGEST=False

REPORT_EXPORT_HTML=True
REPORT_EXPORT_PDF=False
REPORT_PDF_REQUIRE_OPTIONAL_DEPENDENCY=True

RESEARCH_AUTO_LOG_REPORTS=False

# Scenario Runner
ENABLE_SCENARIO_RUNNER=true
SCENARIO_DEFAULT_SYMBOLS="ASELS,THYAO,GARAN"
SCENARIO_DEFAULT_STRATEGY="moving_average_trend"
SCENARIO_USE_SANDBOX=true
SCENARIO_COMPARE_GOLDEN=false
SCENARIO_DEFAULT_STEP_TIMEOUT_SECONDS=60
QUALITY_RUN_SCENARIOS=false


# ==========================================
# RELEASE MANAGER
# ==========================================
ENABLE_RELEASE_MANAGER=true
RELEASE_STAGE="RELEASE_CANDIDATE"
RELEASE_VERSION="0.1.0"
RELEASE_PROFILE="FULL_SAFE_LOCAL"
RELEASE_REQUIRE_NO_BLOCKERS=true
RELEASE_BLOCK_ON_REAL_ORDER_LANGUAGE=true

# === DATA PROVIDER V2 ===
ENABLE_DATA_PROVIDER_V2=true
DATA_PROVIDER_DEFAULT_ORDER="local_file,yfinance"
DATA_PROVIDER_ALLOW_NETWORK=false
DATA_PROVIDER_PREFER_CACHE=true
DATA_PROVIDER_RECORD_LINEAGE=true
DATA_PROVIDER_RECORD_HEALTH=true
DATA_LOCAL_FILE_ENABLED=true
DATA_YFINANCE_ENABLED=true
DATA_INCREMENTAL_ENABLED=true
DATA_FRESHNESS_MAX_AGE_HOURS=48.0

# --- Breadth / Relative Strength ---
ENABLE_BREADTH_ENGINE=True
BREADTH_DIR_NAME=breadth
BREADTH_DEFAULT_UNIVERSE=LIQUID
BREADTH_DEFAULT_BENCHMARK=XU100
BREADTH_DEFAULT_SOURCE=local_file
BREADTH_DEFAULT_TIMEFRAME=1d
BREADTH_LOOKBACK_DAYS=260
BREADTH_SAVE_SNAPSHOTS=True

# Maintenance / Backup Restore
ENABLE_MAINTENANCE=true
BACKUP_VERIFY_AFTER_CREATE=true
RESTORE_REQUIRE_CONFIRM=true
CLEANUP_REQUIRE_CONFIRM=true

# Governance Settings
ENABLE_GOVERNANCE=true
GOVERNANCE_POLICY_VERSION=1.0.0
GOVERNANCE_RUNTIME_GATE_ENABLED=false
GOVERNANCE_RELEASE_GATE_ENABLED=true
GOVERNANCE_RESEARCH_LAB_GATE_ENABLED=true
GOVERNANCE_MAINTENANCE_GATE_ENABLED=true
GOVERNANCE_REPORT_GATE_ENABLED=false

# Knowledge Base
ENABLE_KNOWLEDGE_BASE=true
KNOWLEDGE_DIR_NAME="knowledge"
KNOWLEDGE_INDEX_ON_RUNTIME=false
KNOWLEDGE_RETRIEVE_ON_REVIEW=true
KNOWLEDGE_RETRIEVE_ON_REPORT=true
KNOWLEDGE_SAVE_SEARCH_LOGS=true
KNOWLEDGE_DEFAULT_SEARCH_MODE="AUTO"
KNOWLEDGE_CHUNK_SIZE=800
KNOWLEDGE_CHUNK_OVERLAP=100
KNOWLEDGE_USE_LOCAL_EMBEDDINGS=false
KNOWLEDGE_LOCAL_EMBEDDING_MODEL=""

# --- TELEGRAM COMMAND CENTER ---
ENABLE_TELEGRAM_CENTER=true
TELEGRAM_COMMANDS_ENABLED=false
TELEGRAM_SEND_ENABLED=false
TELEGRAM_DRY_RUN_DEFAULT=true
TELEGRAM_RESEARCH_ONLY_MODE=true

# Auth
# Comma-separated list of Telegram Chat IDs that are allowed to interact with the bot
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# Comma-separated list of admin Chat IDs
TELEGRAM_ADMIN_CHAT_IDS=123456789
TELEGRAM_HASH_CHAT_IDS_IN_LOGS=true
TELEGRAM_BLOCK_UNKNOWN_CHAT=true

# Command
TELEGRAM_ALLOWED_COMMANDS="HELP,STATUS,HEALTH,SIGNALS,REVIEW,PORTFOLIO,STRESS,DRIFT,KB_SEARCH,REPORT,LAB,MAINTENANCE,GOVERNANCE,DIGEST,SETTINGS"
TELEGRAM_BLOCK_DESTRUCTIVE_COMMANDS=true
TELEGRAM_BLOCK_REAL_ORDER_COMMANDS=true
TELEGRAM_REQUIRE_GOVERNANCE_GATE=true

# Message
TELEGRAM_MAX_MESSAGE_CHARS=3500
TELEGRAM_APPEND_DISCLAIMER=true
TELEGRAM_REDACT_OUTPUTS=true

# Rate limit
TELEGRAM_RATE_LIMIT_ENABLED=true
TELEGRAM_RATE_LIMIT_PER_CHAT_PER_MINUTE=10
TELEGRAM_RATE_LIMIT_GLOBAL_PER_MINUTE=30

# Retry
TELEGRAM_RETRY_ENABLED=true
TELEGRAM_MAX_RETRIES=2
TELEGRAM_RETRY_BACKOFF_SECONDS=5
TELEGRAM_TIMEOUT_SECONDS=10

# Digest
TELEGRAM_DIGEST_ENABLED=true
TELEGRAM_DAILY_DIGEST_ENABLED=false
TELEGRAM_WEEKLY_DIGEST_ENABLED=false
TELEGRAM_RUNTIME_DIGEST_ENABLED=false
TELEGRAM_DIGEST_MAX_ITEMS_PER_SECTION=10

# Local Scheduler
ENABLE_LOCAL_SCHEDULER=true
SCHEDULER_DIR_NAME=scheduler
SCHEDULER_TIMEZONE=Europe/Istanbul
SCHEDULER_DRY_RUN_DEFAULT=true
SCHEDULER_RUN_DUE_LIMIT=10
SCHEDULER_GLOBAL_LOCK_TTL_SECONDS=3600
SCHEDULER_JOB_LOCK_TTL_SECONDS=1800
SCHEDULER_DEDUPE_WINDOW_MINUTES=30
BIST_CALENDAR_FILE=bist_holidays.csv
SCHEDULER_CREATE_DEFAULT_JOBS=true
SCHEDULER_REQUIRE_GOVERNANCE_GATE=true
SCHEDULER_BLOCK_DESTRUCTIVE_JOBS=true
SCHEDULER_FORCE_RESEARCH_ONLY=true
SCHEDULER_DISABLE_BROKER=true

# Deployment / First Run
ENABLE_DEPLOYMENT_TOOLS=true
DEPLOYMENT_DIR_NAME=deployment
DEPLOYMENT_DEFAULT_PROFILE=RESEARCH_ONLY
DEPLOYMENT_MIN_PYTHON_VERSION=3.10
DEPLOYMENT_REQUIRE_SAFE_PROFILE=true
