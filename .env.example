# ==============================================================================
# BIST SIGNAL BOT - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env and adjust the values according to your needs.
# The .env file is intentionally excluded from version control (.gitignore).

# ------------------------------------------------------------------------------
# 1. APP / RUNTIME
# ------------------------------------------------------------------------------
# Environment: development, test, or production
APP_ENV=development

# Run mode: research, backtest, paper, live_signal
# Note: Real trading (live_order) is not supported in this phase.
RUN_MODE=research

# Dry run mode disables actual external modifications (e.g. sending real telegram msgs)
DRY_RUN=true

# ------------------------------------------------------------------------------
# 2. PATHS
# ------------------------------------------------------------------------------
# Relative or absolute paths for storage directories
DATA_DIR=data
CACHE_DIR=data/cache
REPORTS_DIR=data/reports

# ------------------------------------------------------------------------------
# 3. DATA PROVIDER
# ------------------------------------------------------------------------------
DEFAULT_DATA_PROVIDER=yfinance
DEFAULT_TIMEFRAME=1d
DEFAULT_HISTORY_PERIOD=2y
DATA_PROVIDER_TIMEOUT_SECONDS=30
DATA_PROVIDER_MAX_RETRIES=2

# ------------------------------------------------------------------------------
# 4. STORAGE
# ------------------------------------------------------------------------------
STORAGE_FORMAT=csv
PREFER_LOCAL_DATA=true
SAVE_FETCHED_DATA=true

# ------------------------------------------------------------------------------
# 5. DATA QUALITY
# ------------------------------------------------------------------------------
ENABLE_DATA_QUALITY_CHECK=true
DATA_QUALITY_MIN_ROWS=100
DATA_QUALITY_MAX_DAILY_RETURN_ABS=0.35
DATA_QUALITY_MAX_ALLOWED_GAP_DAYS=10
DATA_QUALITY_FAIL_ON_ERROR=false

# ------------------------------------------------------------------------------
# 6. MARKET CALENDAR
# ------------------------------------------------------------------------------
BIST_REGULAR_OPEN=10:00
BIST_REGULAR_CLOSE=18:00
BIST_SIGNAL_AFTER_CLOSE_MINUTES=15
BIST_INTRADAY_SIGNAL_ENABLED=false
BIST_DAILY_SIGNAL_ENABLED=true
# Comma separated ISO dates (YYYY-MM-DD)
BIST_MANUAL_HOLIDAYS=2026-01-01,2026-04-23,2026-05-01

# ------------------------------------------------------------------------------
# 7. TELEGRAM (NOTIFICATIONS)
# ------------------------------------------------------------------------------
ENABLE_TELEGRAM=false
TELEGRAM_DRY_RUN=true
# Replace with your actual bot token and chat id when deploying
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=true
TELEGRAM_MESSAGE_MAX_LENGTH=3900

# What to notify about
SEND_STARTUP_NOTIFICATION=true
SEND_HEALTHCHECK_NOTIFICATION=false
SEND_ERROR_NOTIFICATIONS=true
SEND_DATA_QUALITY_WARNINGS=true

# ------------------------------------------------------------------------------
# 8. LOGGING
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_NAME=bist_signal_bot.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
MASK_SECRETS_IN_LOGS=true
DEBUG_TRACEBACKS=false

# ------------------------------------------------------------------------------
# 9. AUDIT
# ------------------------------------------------------------------------------
ENABLE_AUDIT_LOG=true
AUDIT_LOG_FILE_NAME=audit.log

# ------------------------------------------------------------------------------
# 10. ML
# ------------------------------------------------------------------------------
ENABLE_ML=false
ENABLE_GPU=false
ML_RANDOM_SEED=42
ML_MODEL_DIR=data/models

# ------------------------------------------------------------------------------
# 11. OPTIMIZER
# ------------------------------------------------------------------------------
ENABLE_OPTIMIZER=false
OPTIMIZER_RANDOM_SEED=42
OPTIMIZER_MAX_TRIALS=100

# ------------------------------------------------------------------------------
# 12. BACKTEST
# ------------------------------------------------------------------------------
BACKTEST_INITIAL_CAPITAL=100000.0
BACKTEST_COMMISSION_RATE=0.002
BACKTEST_SLIPPAGE_RATE=0.001
BACKTEST_ALLOW_SHORT=false

# ------------------------------------------------------------------------------
# 13. RISK
# ------------------------------------------------------------------------------
MAX_POSITION_SIZE_PCT=0.10
MAX_PORTFOLIO_RISK_PCT=0.02
MAX_DAILY_SIGNALS=10


# ------------------------------------------------------------------------------
# 14. CORPORATE ACTIONS & ADJUSTMENTS
# ------------------------------------------------------------------------------
CORPORATE_ACTIONS_DIR_NAME=corporate_actions
CORPORATE_ACTIONS_FILE_NAME=corporate_actions.json
AUTO_INITIALIZE_CORPORATE_ACTIONS=true
ENABLE_PRICE_ADJUSTMENTS=false
DEFAULT_ADJUSTMENT_POLICY=FLAG_ONLY
ADJUSTMENT_SAVE_ADJUSTED_DATA=false
ADJUSTMENT_APPLY_TO_OHLC=true
ADJUSTMENT_APPLY_TO_VOLUME=true
ADJUSTMENT_FAIL_ON_ERROR=true
ADJUSTMENT_REQUIRE_VERIFIED_ACTIONS=false

# === COST MODEL (Phase 26) ===
ENABLE_COST_MODEL=True
COST_SCENARIO=BASE

COMMISSION_MODEL_TYPE=BPS
COMMISSION_BPS=5.0
COMMISSION_FLAT_FEE=0.0
COMMISSION_MINIMUM=0.0
TRANSACTION_TAX_BPS=0.0
OTHER_FEE_BPS=0.0

SLIPPAGE_MODEL_TYPE=HYBRID
FIXED_SLIPPAGE_BPS=5.0
VOLUME_IMPACT_FACTOR=10.0
VOLATILITY_IMPACT_FACTOR=0.25
MIN_SLIPPAGE_BPS=0.0
MAX_SLIPPAGE_BPS=100.0

SPREAD_MODEL_TYPE=LIQUIDITY_BUCKET
FIXED_SPREAD_BPS=5.0
HIGH_LIQUIDITY_SPREAD_BPS=3.0
MEDIUM_LIQUIDITY_SPREAD_BPS=8.0
LOW_LIQUIDITY_SPREAD_BPS=20.0

LIQUIDITY_HIGH_TURNOVER_TRY=100000000.0
LIQUIDITY_MEDIUM_TURNOVER_TRY=10000000.0
COST_DEFAULT_AVG_DAILY_VOLUME=0.0
COST_DEFAULT_AVG_DAILY_TURNOVER=0.0
