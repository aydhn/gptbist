APP_NAME=BIST Signal Bot
APP_ENV=development
LOG_LEVEL=INFO

DATA_DIR=data
CACHE_DIR=cache
REPORTS_DIR=reports

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

DEFAULT_TIMEZONE=Europe/Istanbul
DEFAULT_MARKET=BIST

DRY_RUN=true
ENABLE_TELEGRAM=false
ENABLE_ML=false
ENABLE_OPTIMIZER=false
ENABLE_GPU=false
