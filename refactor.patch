+                safety_level=ConfigSafetyLevel.SENSITIVE,
+                secret=True
+            ),
+            ConfigDefinition(
+                key="TELEGRAM_ALLOWED_CHAT_IDS",
+                module=ConfigModule.TELEGRAM,
+                value_type=ConfigValueType.SECRET,
+                default_value=[],
